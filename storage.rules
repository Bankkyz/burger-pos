rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == "admin@example.com";
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
